# Example .env file for Anju Medical Appointment System
# Copy this file to .env and fill in actual values

MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
TZ=UTC
SPRING_PROFILES_ACTIVE=docker
NACOS_SERVER_ADDR=nacos:8848
NACOS_AUTH_ENABLE=false
# Enable Nacos for full production deployment (set to false for local dev without Nacos)
NACOS_CONFIG_ENABLED=true
NACOS_DISCOVERY_ENABLED=true

# REQUIRED: Set to a strong random 256-bit (32-byte) value — never use the default
# Generate one with: openssl rand -hex 32
SECURITY_JWT_SECRET=change-this-to-a-strong-random-256-bit-secret-key-here
